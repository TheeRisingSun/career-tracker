{
  "name": "career-tracker-root",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "npm run build --workspace=frontend && rm -rf dist && cp -r frontend/dist dist",
    "install-all": "npm install",
    "dev": "concurrently \"npm run dev --workspace=frontend\" \"npm run dev --workspace=backend\"",
    "start": "node backend/server.js"
  },
  "workspaces": [
    "frontend",
    "backend"
  ],
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1014.0",
    "@aws-sdk/client-secrets-manager": "^3.1014.0",
    "@aws-sdk/lib-storage": "^3.1014.0",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.3.0",
    "multer": "^1.4.5-lts.1"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
