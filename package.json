{
  "name": "career-tracker-root",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "npm run build --workspace=frontend && rm -rf dist && cp -r frontend/dist dist",
    "install-all": "npm install",
    "dev": "concurrently \"npm run dev --workspace=frontend\" \"npm run dev --workspace=backend\"",
    "start": "node backend/server.js"
  },
  "workspaces": [
    "frontend",
    "backend"
  ],
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
